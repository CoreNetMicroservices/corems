{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://localhost:5102" }
    }
  },
  "ConnectionStrings": {
    "corems": "Host=localhost;Port=5432;Database=corems;Username=postgres;Password=postgres;Search Path=document_ms"
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "documents",
    "ForcePathStyle": true
  },
  "Document": {
    "MaxUploadSizeBytes": 10485760,
    "AllowedExtensions": ["pdf", "png", "jpg", "jpeg", "gif", "doc", "docx", "xls", "xlsx", "txt", "csv", "zip"],
    "BaseUrl": "http://localhost:5102",
    "StreamBufferSize": 81920,
    "LinkSigningKey": "",
    "DefaultLinkExpirationMinutes": 1440
  },
  "Jwt": {
    "Issuer": "http://localhost:5100",
    "Audience": "corems",
    "SecretKey": ""
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:8080" ]
  },
  "AllowedHosts": "*"
}
